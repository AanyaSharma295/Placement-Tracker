    "lucide-react": "^0.117.0",
    "next": "14.2.7",
    "prisma": "^5.19.3",
    "radix-ui": "^1.5.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "^2.12.7",
    "shadcn": "^2.10.0",
    "tailwind-merge": "^2.5.2",
    "tw-animate-css": "^1.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^9",
