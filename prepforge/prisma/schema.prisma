generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  name      String?
  email     String   @unique
  image     String?
  createdAt DateTime @default(now())

  handles          Handles?
  contestHistory   ContestHistory[]
  contestStats     ContestStats[]
  leetcodeStats    LeetcodeStats?
  xp               XP[]
  badges           UserBadge[]
  questionProgress QuestionProgress[]
  topicProgress               TopicProgress[]
  subjectQuestionProgress     SubjectQuestionProgress[]
}

model Handles {
  id          String  @id @default(cuid())
  userId      String  @unique
  codeforces  String?
  leetcode    String?
  atcoder     String?
  hackerrank  String?

  user User @relation(fields: [userId], references: [id])
}

model ContestHistory {
  id          String   @id @default(cuid())
  userId      String
  platform    String
  contestId   String
  contestName String
  rating      Int
  rank        Int
  date        DateTime

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, contestId, platform])
}

model ContestStats {
  id            String    @id @default(cuid())
  userId        String
  platform      String
  handle        String?
  currentRating Int
  maxRating     Int
  contestCount  Int
  lastSyncedAt  DateTime?

  user User @relation(fields: [userId], references: [id])
}

model LeetcodeStats {
  id          String   @id @default(cuid())
  userId      String   @unique
  handle      String?
  easy        Int      @default(0)
  medium      Int      @default(0)
  hard        Int      @default(0)
  totalSolved Int      @default(0)
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model XP {
  id     String @id @default(cuid())
  userId String
  points Int
  reason String

  user User @relation(fields: [userId], references: [id])
}

model Badge {
  id          String      @id @default(cuid())
  name        String
  description String
  userBadges  UserBadge[]
}

model UserBadge {
  id      String @id @default(cuid())
  userId  String
  badgeId String

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])
}

model Question {
  id         String @id @default(cuid())
  title      String
  difficulty String
  topic      String
  link       String

  companies        CompanyQuestion[]
  questionProgress QuestionProgress[]
}

model Company {
  id        String @id @default(cuid())
  name      String
  slug      String @unique

  questions CompanyQuestion[]
}

model CompanyQuestion {
  companyId  String
  questionId String

  company  Company  @relation(fields: [companyId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@id([companyId, questionId])
}

model QuestionProgress {
  userId     String
  questionId String
  status     String @default("NOT_STARTED")

  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@id([userId, questionId])
}

model RevisionTopic {
  id      String @id @default(cuid())
  subject String
  title   String
  content String
  order   Int    @default(0)
  slug    String @default("")

  progress  TopicProgress[]
  questions SubjectQuestion[]
  @@unique([subject, slug])
}

model TopicProgress {
  userId  String
  topicId String
  status  String @default("NOT_STARTED")

  user  User          @relation(fields: [userId], references: [id])
  topic RevisionTopic @relation(fields: [topicId], references: [id])

  @@id([userId, topicId])
}

model SubjectQuestion {
  id              String   @id @default(cuid())
  topicId         String
  type            String
  question        String
  difficulty      String
  frequency       String
  companies       String[]
  interviewerNote String?
  options         String[]
  correctOption   Int?
  explanation     String?
  order           Int      @default(0)

  topic    RevisionTopic             @relation(fields: [topicId], references: [id])
  progress SubjectQuestionProgress[]
}

model SubjectQuestionProgress {
  userId         String
  questionId     String
  status         String    @default("NOT_STARTED")
  bookmarked     Boolean   @default(false)
  attempted      Boolean   @default(false)
  selectedOption Int?
  isCorrect      Boolean?
  attemptedAt    DateTime?
  lastRevisedAt  DateTime?

  user     User            @relation(fields: [userId], references: [id])
  question SubjectQuestion @relation(fields: [questionId], references: [id])

  @@id([userId, questionId])
}